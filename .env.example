# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/informakit

# ─── Auth ─────────────────────────────────────────────────────
# Random secret for signing session JWTs (min. 32 chars)
JWT_SECRET=your-super-secret-key-min-32-characters

# ─── Admin Account ────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# ─── Anthropic Claude ─────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── AWS S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-central-1
S3_BUCKET_NAME=informakit-uploads

# ─── Email Notifications (SMTP) ───────────────────────────────
# Example with Gmail: use an App Password (not your account password)
# Google App Passwords: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
OWNER_EMAIL=your@gmail.com
